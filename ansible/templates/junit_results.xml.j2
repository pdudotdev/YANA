<?xml version="1.0" encoding="UTF-8"?>
<testsuites name="network_qa"
            tests="{{ qa_results | length }}"
            failures="{{ qa_results | selectattr('passed', 'equalto', false) | list | length }}"
            timestamp="{{ lookup('pipe', 'date -u +%Y-%m-%dT%H:%M:%SZ') }}">
  <testsuite name="network_qa"
             tests="{{ qa_results | length }}"
             failures="{{ qa_results | selectattr('passed', 'equalto', false) | list | length }}">
{% for r in qa_results %}
    <testcase name="{{ r.scenario }}" classname="{{ r.scenario }}">
      <properties>
        <property name="device" value="{{ r.device }}"/>
        <property name="rfc_ref" value="{{ r.rfc_ref }}"/>
        <property name="description" value="{{ r.description | e }}"/>
        <property name="rfc_citation" value="{{ r.rfc_citation | e }}"/>
      </properties>
{% if not r.passed %}
      <failure message="{{ r.description | e }}">{{ r.details | default('') | e }}</failure>
{% endif %}
    </testcase>
{% endfor %}
  </testsuite>
</testsuites>
